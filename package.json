{
  "name": "backroom",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "backend": "npm --prefix backend run start:dev",
    "frontend": "npm --prefix frontend run start",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "install:all": "npm --prefix backend install && npm --prefix frontend install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
